<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_approval_view_form" model="ir.ui.view">
        <field name="name">group.approval.view.form</field>
        <field name="model">group.approval</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <h3>The quantity discrepancy exceeds the allowable tolerance (0.5%). Procurement Officer approval is required before proceeding.</h3>
                    </group>
                    <footer>
                        <button string="Request Approval" name="action_request" type="object" class="oe_highlight"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
