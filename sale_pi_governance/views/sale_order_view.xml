<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_view" model="ir.ui.view">
        <field name="name">Sale Order View</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"></field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='validity_date']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <!-- add page after other information -->
            <xpath expr="//page[@name='other_information']" position="after">
                <page name="pi_expiary" string="PI Expiary" invisible="finance_group_check or intial_page_hide_rule">

                    <group>
                        <!-- Row 1: CCM -->
                        <group string="CCM">
                            <field name="finance_group_check" invisible="1"></field>
                            <field name="approve" string="Approve" readonly="reject" groups="zencore_groups.group_zencore_clm_ccm"/>
                            <field name="reject" string="Reject" readonly="approve" groups="zencore_groups.group_zencore_clm_ccm"/>
                        </group>

                        <!-- Row 2: Finance Manager -->
                        <group string="Finance Manager" invisible="finance_manager_hide_rule">
                            <field name="approve_finance" string="Approve" readonly="not approve or reject_finance" groups="zencore_groups.group_zencore_clm_finance"/>
                            <field name="reject_finance" string="Reject" readonly="not approve or approve_finance" groups="zencore_groups.group_zencore_clm_finance"/>
                        </group>
                    </group>


                    <group>
                        <field name="write_date" readonly="1" string="Submit Date:"/>
                        <field name="write_uid" readonly="1" string="Submitted by:"/>
                    </group>

                    <!-- <separator string="Other Information"/>
                    <group>
                        <field name="write_uid" string="Name"></field>
                        <field name="approver_groups"></field>
                        <field name="write_date" string="Approve time and date"></field> 
                        <field name="status_text" readonly="1"/>
                    </group> -->

                    <separator string="Approval History"/>
                    <field name="approval_line_ids" readonly="1">
                        <list>
                            <field name="name" string="Name"/>
                            <field name="designation" string="Designation"/>
                            <field name="approve_date" string="Approve Date"/>
                            <field name="status" string="Status"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>


    <!-- request for quotation ar jonno action add korlam -->
    <record id="request_for_quotation_action" model="ir.actions.server">
        <field name="name">Expiary Date Extension</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = record.action_request_pi_extension()</field>
    </record>

</odoo>